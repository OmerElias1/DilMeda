{
  "expo": {
    "name": "DilMeda",
    "slug": "dilmeda",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/image.png",
    "scheme": "dilmeda",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.oek04.dilmeda"
    },
    "android": {
      "package": "com.oek04.dilmeda",
      "adaptiveIcon": {
        "backgroundColor": "#000000"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/image.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/image.png",
          "color": "#FFD700"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1b7f1b1b-381f-49ba-8e82-7b9fe964cecd"
      }
    },
    "owner": "oek_04"
  }
}
